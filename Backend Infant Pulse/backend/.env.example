INFANT_PULSE_APP_NAME=Infant Pulse Backend
INFANT_PULSE_APP_ENV=development
INFANT_PULSE_DEBUG=false
INFANT_PULSE_LOG_LEVEL=INFO
INFANT_PULSE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/infant_pulse
INFANT_PULSE_INGEST_QUEUE_SIZE=10000
INFANT_PULSE_RECENT_VITALS_LIMIT=100
INFANT_PULSE_INITIAL_BABY_COUNT=5
INFANT_PULSE_ENABLE_DB_SEED=true
INFANT_PULSE_ENABLE_BACKGROUND_WORKER=true
INFANT_PULSE_CORS_ORIGINS=["*"]
INFANT_PULSE_SIMULATOR_API_URL=http://127.0.0.1:8000
INFANT_PULSE_SIMULATOR_INTERVAL_SECONDS=1.0
INFANT_PULSE_SIMULATOR_BABY_COUNT=5
INFANT_PULSE_SIMULATOR_ANOMALY_PROBABILITY=0.08
